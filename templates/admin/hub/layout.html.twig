{% extends 'layouts/app.html.twig' %}

{% block title %}{{ hub_title|default('Hub') }} — Mercuriale.io{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('css/admin-hub.css') }}">
{% endblock %}

{% block breadcrumb %}
    {% include 'components/_breadcrumb.html.twig' with {
        breadcrumbs: hub_breadcrumbs|default([{ label: hub_title }])
    } %}
{% endblock %}

{% block content %}
    {% block hub_content %}{% endblock %}
{% endblock %}
