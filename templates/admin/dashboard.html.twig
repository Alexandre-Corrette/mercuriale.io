{% extends 'layouts/app.html.twig' %}

{% block title %}Tableau de bord — Mercuriale.io{% endblock %}

{% block breadcrumb %}
    {% include 'components/_breadcrumb.html.twig' %}
{% endblock %}

{% block content %}
<div class="dashboard-hub">
    <div class="m-tile-grid">
        {# Tile 1: Bons de livraison — active #}
        {% include 'components/_dashboard_tile.html.twig' with {
            label: 'Bons de livraison', icon: 'fa-file-invoice',
            url: path('admin_hub_bl'), color: 'navy',
            badge_count: alerte_count
        } only %}

        {# Tile 2: Produits — active #}
        {% include 'components/_dashboard_tile.html.twig' with {
            label: 'Produits', icon: 'fa-box',
            url: path('admin_hub_produits'), color: 'coral'
        } only %}

        {# Tiles 3-6: hidden until their hub pages exist (MERC-74-77) #}
        {# Fournisseurs (blue), Statistiques (green), Production (orange), Profil (blue) #}
    </div>
</div>
{% endblock %}
