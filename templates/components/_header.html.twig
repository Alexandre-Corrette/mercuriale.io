{#
  Header Component

  Params:
    logo_path:       string (optional, default: 'images/logo-mercuriale-rectangulaire.png')
    show_user_info:  bool   (optional, default: true)
#}
{% set _logo = logo_path|default('images/logo-mercuriale-rectangulaire.png') %}
{% set _show_user = show_user_info|default(true) %}

<header class="m-header">
    <div class="m-header__inner">
        <a href="{{ path('admin') }}" class="m-header__logo-link">
            <img src="{{ asset(_logo) }}" alt="Mercuriale.io" class="m-header__logo">
        </a>

        {% if _show_user and app.user %}
        <div class="m-header__right">
            <div class="m-header__user">
                <i class="fas fa-user-circle" aria-hidden="true"></i>
                <span class="m-header__user-name">{{ app.user.prenom|default('') }} {{ app.user.nom|default('') }}</span>
            </div>

            {% set etablissements = user_etablissements() %}
            {% set selected = selected_etablissement() %}
            {% if selected %}
            <div class="m-header__restaurant-dropdown"
                 data-controller="header-dropdown">
                {% if etablissements|length > 1 %}
                    <button type="button"
                            class="m-header__restaurant-toggle"
                            aria-expanded="false"
                            aria-haspopup="true"
                            data-header-dropdown-target="toggle"
                            data-action="click->header-dropdown#toggle">
                        <i class="fas fa-store" aria-hidden="true"></i>
                        <span class="m-header__restaurant-name">{{ selected.nom }}</span>
                        <i class="fas fa-chevron-down m-header__restaurant-chevron" aria-hidden="true"></i>
                    </button>
                    <ul class="m-header__restaurant-menu"
                        data-header-dropdown-target="menu"
                        role="menu">
                        {% for etab in etablissements %}
                            <li role="menuitem">
                                <a href="{{ path('app_etablissement_switch', {id: etab.id}) }}"
                                   class="m-header__restaurant-option{% if etab.id == selected.id %} m-header__restaurant-option--active{% endif %}">
                                    <i class="fas fa-store" aria-hidden="true"></i>
                                    {{ etab.nom }}
                                    {% if etab.id == selected.id %}
                                        <i class="fas fa-check m-header__restaurant-check" aria-hidden="true"></i>
                                    {% endif %}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="m-header__restaurant">
                        <i class="fas fa-store" aria-hidden="true"></i>
                        <span class="m-header__restaurant-name">{{ selected.nom }}</span>
                    </div>
                {% endif %}
            </div>
            {% endif %}

            {% set _date = current_date() %}
            {% if _date %}
            <div class="m-header__date">
                <i class="fas fa-calendar" aria-hidden="true"></i>
                <span>{{ _date }}</span>
            </div>
            {% endif %}
        </div>
        {% endif %}
    </div>
</header>
