{% extends 'admin/hub/layout.html.twig' %}

{% set hub_title = 'Modifier le mot de passe' %}
{% set hub_breadcrumbs = [
    { label: 'Profil', url: path('app_profil_hub') },
    { label: 'Mes coordonnees', url: path('app_profil_coordonnees') },
    { label: 'Mot de passe' }
] %}
{% set back_url = path('app_profil_coordonnees') %}

{% block title %}Modifier le mot de passe — Mercuriale.io{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/profil.css') }}">
{% endblock %}

{% block hub_content %}
<div class="hub-content">
    <h1 class="hub-title"><i class="fas fa-lock"></i> Modifier le mot de passe</h1>

    {% for message in app.flashes('success') %}
        <div class="profil-form__flash profil-form__flash--success">
            <i class="fas fa-check-circle"></i> {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="profil-form__flash profil-form__flash--error">
            <i class="fas fa-exclamation-circle"></i> {{ message }}
        </div>
    {% endfor %}

    {{ form_start(form, {attr: {class: 'profil-form'}}) }}

        <div class="profil-form__field">
            {{ form_label(form.currentPassword, null, {label_attr: {class: 'profil-form__label'}}) }}
            {{ form_widget(form.currentPassword, {attr: {class: 'profil-form__input'}}) }}
            {{ form_errors(form.currentPassword) }}
        </div>

        <div class="profil-form__field">
            {{ form_label(form.newPassword.first, null, {label_attr: {class: 'profil-form__label'}}) }}
            {{ form_widget(form.newPassword.first, {attr: {class: 'profil-form__input'}}) }}
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div class="profil-form__field">
            {{ form_label(form.newPassword.second, null, {label_attr: {class: 'profil-form__label'}}) }}
            {{ form_widget(form.newPassword.second, {attr: {class: 'profil-form__input'}}) }}
            {{ form_errors(form.newPassword.second) }}
        </div>

        {{ form_rest(form) }}

        <div class="profil-form__actions">
            <button type="submit" class="btn btn--primary">
                <i class="fas fa-lock"></i> Modifier le mot de passe
            </button>
            <a href="{{ path('app_profil_coordonnees') }}" class="btn btn--secondary">
                <i class="fas fa-times"></i> Annuler
            </a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
